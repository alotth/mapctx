{
  "name": "mapctx",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "vscode:prepublish": "npm run vscode:prepublish --workspace mapctx",
    "compile": "npm run compile --workspace mapctx",
    "watch": "npm run watch --workspace mapctx",
    "watch:esbuild": "npm run watch:esbuild --workspace mapctx",
    "watch:tsc": "npm run watch:tsc --workspace mapctx",
    "package": "npm run package --workspace mapctx",
    "compile-tests": "npm run compile-tests --workspace mapctx",
    "watch-tests": "npm run watch-tests --workspace mapctx",
    "check-types": "npm run check-types --workspace mapctx",
    "lint": "npm run lint --workspace mapctx",
    "test": "npm run test --workspace mapctx",
    "test:parser": "npm run test:parser --workspace mapctx --",
    "dev:standalone": "npm run dev:standalone --workspace mapctx",
    "watch:logs": "npm run watch:logs --workspace mapctx",
    "logs": "npm run logs --workspace mapctx",
    "prepare-publish": "npm run prepare-publish --workspace mapctx",
    "build:opencode-plugin": "node scripts/build-opencode-plugin.mjs",
    "install:opencode-plugin": "node scripts/install-opencode-plugin.mjs",
    "build:core": "npm run build --workspace @mapctx/core",
    "build:sync-engine": "npm run build:core && npm run build --workspace @mapctx/sync-engine",
    "test:sync-engine": "npm run build:core && npm run test --workspace @mapctx/sync-engine"
  }
}
